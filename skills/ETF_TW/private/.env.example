# ==============================================================
# ETF_TW 私有環境變數範本
# 複製本檔為 private/.env 並填入真實值
# 本檔可 commit；private/.env 已 gitignore，絕對不可 commit
# ==============================================================

# ── Agent 身份 ────────────────────────────────────────────────
# 必填：對應 instances/ 下的目錄名稱（例如 etf_master）
# 所有腳本都透過此變數定位 instance 資料夾與 state 檔案
AGENT_ID=etf_master

# ── 永豐金證券 (Shioaji / SinoPac) ───────────────────────────
# 以下憑證從永豐金智能客服 / API 申請頁取得
# 申請網址：https://www.sinotrade.com.tw/CSCenter/CSCenter_13_1

# 身分證字號（登入帳號）
SINOPAC_PERSON_ID=A123456789

# 網頁登入密碼
SINOPAC_PASSWD=your_login_password

# CA 憑證密碼（申請 API 憑證時設定）
SINOPAC_CERT_PASSWD=your_ca_cert_password

# CA 憑證檔案路徑（相對於 ETF_TW 根目錄）
# 憑證為 .pfx 格式，申請後下載放入 private/certs/
SINOPAC_CA_PATH=private/certs/Sinopac.pfx

# ── 交易帳號（與 instance_config.json 的 account_id 對應）────
# 7 碼數字，從永豐金帳戶資訊 → 股票帳號 取得
SINOPAC_ACCOUNT=0000000

# ── Telegram Bot（Hermes Agent 訊息推播）────────────────────
# BOT_TOKEN：從 @BotFather 建立 bot 後取得（格式：數字:英數字串）
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ALLOWED_USERS：允許操控此 bot 的 Telegram 使用者 ID（數字）
# 多個 ID 以逗號分隔，例如：12345678,87654321
# 取得自己 ID 的方法：傳訊給 @userinfobot
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# HOME_CHANNEL：Hermes Agent 主動推播的目標頻道或聊天 ID（數字）
# 個人對話：與 ALLOWED_USERS 相同
# 群組頻道：需為負數（例如 -1001234567890）
TELEGRAM_HOME_CHANNEL=your_telegram_chat_id

# CHAT_NAME：顯示用的聊天名稱，用於 cron 報告的收件人欄位
# 可填入你的 Telegram 名字或頻道名稱
TELEGRAM_CHAT_NAME=Your Name

# ── Worldmonitor（全球風險雷達）──────────────────────────────
# 全球供應鏈、地緣政治、台灣海峽風險信號來源
# base_url 為服務端點，api_key 由服務提供方核發
# 若無存取權，在 instance_config.json 設 "worldmonitor": {"enabled": false}
WORLDMONITOR_BASE_URL=https://worldmonitor-gamma-mocha.vercel.app
WORLDMONITOR_API_KEY=your_api_key_here

# ── 選填：LLM API（dashboard AI 建議功能）────────────────────
# 若使用 Hermes Agent 內建 LLM 設定（config.yaml），此處通常不需填
# 若需要直接呼叫 API，填入對應金鑰
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
