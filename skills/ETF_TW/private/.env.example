# ==============================================================
# ETF_TW 私有環境變數範本
# 複製本檔為 private/.env 並填入真實值
# 本檔可 commit；private/.env 已 gitignore，絕對不可 commit
# ==============================================================

# ── Agent 身份 ────────────────────────────────────────────────
# 必填：對應 instances/ 下的目錄名稱
AGENT_ID=etf_master

# ── 永豐金證券 (Shioaji / SinoPac) ───────────────────────────
# 從永豐金智能客服 / API 申請頁取得
SINOPAC_PERSON_ID=A123456789
SINOPAC_PASSWD=your_login_password
SINOPAC_CERT_PASSWD=your_ca_cert_password

# CA 憑證路徑（相對於 ETF_TW 根目錄）
# 憑證申請：https://www.sinotrade.com.tw/CSCenter/CSCenter_13_1
SINOPAC_CA_PATH=private/certs/Sinopac.pfx

# ── 交易帳號（與 instance_config.json 對應）──────────────────
# 通常是 7 碼數字，從永豐金帳戶資訊取得
SINOPAC_ACCOUNT=0000000

# ── Worldmonitor（全球風險雷達）──────────────────────────────
# base_url 與 api_key 由系統管理員提供，或聯繫專案維護者
# 若無 worldmonitor 存取權，可在 instance_config.json 設 enabled: false
WORLDMONITOR_BASE_URL=https://worldmonitor-gamma-mocha.vercel.app
WORLDMONITOR_API_KEY=your_api_key_here

# ── 選填：LLM API（dashboard AI 建議功能）────────────────────
# 若使用 Hermes Agent 的 LLM，此處通常不需填（由 config.yaml 管理）
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
